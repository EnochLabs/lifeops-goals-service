# ─────────────────────────────────────────────────────────────
# LifeOps Goals Service — Environment Variables
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# App
APP_NAME="LifeOps Goals Service"
ENVIRONMENT=development
DEBUG=true
PORT=8002
SERVICE_HOST=0.0.0.0

# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=lifeops_goals

# Redis
REDIS_URL=redis://localhost:6379/0

# Internal service communication
INTERNAL_API_KEY=change-this-to-a-long-random-secret

# URLs of sibling services (use Docker service names in compose)
AUTH_SERVICE_INTERNAL_URL=http://auth-service:8001
AI_SERVICE_INTERNAL_URL=http://ai-service:8007

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Goal behaviour
MOMENTUM_WINDOW_DAYS=14
MOMENTUM_LOW_THRESHOLD=40.0
MAX_PHASES_PER_GOAL=6
MAX_ACTIONS_PER_DECOMPOSITION=200

# Rate limits
GLOBAL_RATE_LIMIT_PER_MINUTE=300
CREATE_GOAL_RATE_LIMIT=20
DECOMPOSE_GOAL_RATE_LIMIT=5
COMPLETE_ACTION_RATE_LIMIT=200

# Background jobs
MOMENTUM_RECALC_INTERVAL_HOURS=6
RECURRING_ACTION_GEN_INTERVAL_HOURS=12

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false
